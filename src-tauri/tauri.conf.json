{
  "productName": "Orbit",
  "version": "0.5.1",
  "identifier": "com.k1031oct.orbit",
  "build": {
    "frontendDist": "../out",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "next build",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Orbit",
        "width": 1200,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-eval' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' blob: data:; connect-src 'self' https://sql.js.org; font-src 'self' data:; worker-src 'self' blob:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "k1031oct",
    "windows": {
      "wix": {
        "language": "en-US",
        "upgradeCode": "E501FD44-C5DA-4418-8473-E1A54FDCD8E4"
      }
    }
  }
}
