{
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "dialog:allow-open",
    "dialog:default",
    "fs:allow-write",
    "fs:allow-write-text-file",
    "fs:allow-read",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    {
      "identifier": "fs:scope",
      "allow": ["C:\\Engineering\\**"]
    },
    "fs:default",
    "shell:allow-open",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:default",
    "process:default",
    "log:default"
  ]
}
