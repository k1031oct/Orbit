{
  "identifier": "main-capability",
  "description": "Capability for the main window",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:path:default",
    "core:event:default",
    "core:window:default",
    "core:app:default",
    "core:resources:default",
    "core:menu:default",
    "core:tray:default",
    "dialog:allow-open",
    "dialog:default",
    "fs:allow-write",
    "fs:allow-write-text-file",
    "fs:allow-read",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-read-dir",
    {
      "identifier": "fs:scope",
      "allow": ["C:\\Engineering\\**"]
    },
    "fs:default",
    "shell:allow-open",
    "shell:allow-spawn",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "git-cmd", "cmd": "git", "args": [ { "validator": ".*" } ] },
        { "name": "adb-cmd", "cmd": "adb", "args": [ { "validator": ".*" } ] },
        { "name": "git-clone", "args": [ "clone", { "validator": ".*" }, { "validator": ".*" } ], "cmd": "git" },
        { "name": "git-pull", "args": [ "pull" ], "cmd": "git" },
        { "name": "git-status", "args": [ "status" ], "cmd": "git" },
        { "name": "git-version", "args": [ "version" ], "cmd": "git" },
        { "name": "adb-cmd-specific", "cmd": "adb", "args": [ { "validator": ".*" } ] },
        { "name": "win-cmd", "cmd": "cmd", "args": [ { "validator": ".*" } ] },
        { "name": "java-cmd", "cmd": "java", "args": [ { "validator": ".*" } ] }
      ]
    },
    "shell:default",
    "process:default",
    "log:default"
  ]
}
